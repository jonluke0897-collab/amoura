# Copy to .env and fill in. Never commit .env.

# Convex — from `npx convex dev` output or the Convex dashboard.
EXPO_PUBLIC_CONVEX_URL=

# Clerk — publishable key from Clerk dashboard.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# RevenueCat — SDK keys (iOS + Android) from RevenueCat dashboard. Added in Phase 6.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# PostHog — project API key from PostHog project settings.
EXPO_PUBLIC_POSTHOG_KEY=

# OneSignal — App ID from OneSignal dashboard. Added in Phase 4. The REST
# API key is set separately in Convex env (`npx convex env set
# ONESIGNAL_API_KEY ...` and `... ONESIGNAL_APP_ID ...`) — not here.
EXPO_PUBLIC_ONESIGNAL_APP_ID=
